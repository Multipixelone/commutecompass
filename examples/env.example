# Required environment variables for commutecompass
# Copy this to /etc/commutecompass/env or similar and fill in values

GOOGLE_MAPS_API_KEY=
GOOGLE_OAUTH_CLIENT_SECRET=
OPENCODE_GO_TOKEN=

# Required only when [notify].mode = "telegram" in config.toml. In the default
# "stdout" mode commutecompass never touches the Telegram API directly —
# OpenClaw does the delivery via contrib/openclaw-send.sh.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Required only when [home_assistant].enabled = true in config.toml.
# Long-lived access token from HA: Profile → Long-Lived Access Tokens.
HOME_ASSISTANT_TOKEN=